# ============================================
# CONFIGURAÇÃO DO AMBIENTE - Sea Logistics
# ============================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no repositório!

# --------------------------------------------
# Azure AD / Microsoft 365 Configuration
# --------------------------------------------
VITE_AZURE_CLIENT_ID=your_azure_client_id_here
VITE_AZURE_REDIRECT_URI=https://your-domain.netlify.app/auth/callback

# URL do backend (Render/local) — usado para auth JWT, email e push notifications
VITE_BACKEND_URL=https://your-backend-url.onrender.com
VITE_EMAIL_SERVER_URL=https://your-backend-url.onrender.com

# --------------------------------------------
# Firebase Configuration (Frontend)
# --------------------------------------------
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_PROJECT_ID=sealogistics-4f899
VITE_FIREBASE_AUTH_DOMAIN=sealogistics-4f899.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=sealogistics-4f899.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=your_app_id

# Chave VAPID do Firebase Cloud Messaging (Console > Project Settings > Cloud Messaging)
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# Login por código (Firebase Auth)
VITE_FIREBASE_OTP_ENABLED=true
VITE_FIREBASE_EMAIL_LINK_URL=https://your-domain.netlify.app/auth/email-link

# --------------------------------------------
# Backend / Server (pasta server/)
# --------------------------------------------
PORT=3001
NODE_ENV=development

# JWT para API REST
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=24h

# Código secreto para cadastro de administrador (/register)
# Use VITE_ para o frontend validar antes de gravar no Firestore
VITE_ADMIN_CODE=your-secret-admin-code-here

# Firebase Admin — JSON da service account (uma linha, string JSON)
# Obtenha em: Firebase Console > Project Settings > Service Accounts
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Ou use arquivo de credenciais:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --------------------------------------------
# Email — SendGrid (preferencial) ou Gmail/Nodemailer
# --------------------------------------------
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Sea Logistics

# Fallback Gmail (Nodemailer)
VITE_EMAIL_USER=your-email@gmail.com
VITE_EMAIL_APP_PASSWORD=your-app-password

# --------------------------------------------
# Push Notifications — Firebase Cloud Messaging
# --------------------------------------------
# Configure VITE_FIREBASE_VAPID_KEY no frontend e FIREBASE_SERVICE_ACCOUNT no backend.
# Não é necessário Twilio ou Meta WhatsApp.

# --------------------------------------------
# Azure (Backend Excel token exchange)
# --------------------------------------------
AZURE_CLIENT_SECRET=your_azure_client_secret
REACT_APP_AZURE_CLIENT_ID=your_azure_client_id

# --------------------------------------------
# Opcional
# --------------------------------------------
