# ============================================
# Sea Logistics — Backend (server/)
# Copie estas variáveis no painel do Render
# ============================================

# Ambiente
NODE_ENV=development
PORT=3001

# --------------------------------------------
# OBRIGATÓRIO — Auth, login e Firestore rules
# --------------------------------------------

# Segredo para JWT da API (/api/auth/login)
JWT_SECRET=sealogistics-jwt-secret-altere-em-producao
JWT_EXPIRES_IN=24h

# Firebase Admin — JSON da service account em UMA LINHA
# Firebase Console > Project Settings > Service Accounts > Generate new private key
# Cole o JSON inteiro entre aspas ou sem quebras de linha
FIREBASE_SERVICE_ACCOUNT=

# Código para cadastro de administrador via API
ADMIN_CODE=9Kx4Tq8M2Zp7

# --------------------------------------------
# Email — Gmail (Nodemailer) ou SendGrid
# Use um dos dois. Gmail já configurado abaixo.
# --------------------------------------------

VITE_EMAIL_USER=vinhatti2002@gmail.com
VITE_EMAIL_APP_PASSWORD=zqkweyqhskoahfxh

# SendGrid (opcional — tem prioridade se preenchido)
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_FROM_NAME=Sea Logistics

# --------------------------------------------
# Opcional — integração Azure / Excel
# --------------------------------------------

# REACT_APP_AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
