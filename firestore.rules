rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Função para verificar se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Função para verificar se o usuário é admin
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    // Função para verificar se o usuário é operador
    function isOperator() {
      return isAuthenticated() && (
        request.auth.token.role == 'operator' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'operator')
      );
    }

    function isStaff() {
      return isAdmin() || isOperator();
    }

    function isCompanyUser() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'company_user';
    }

    function getUserCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }
    
    // Função para verificar se o usuário é da mesma empresa
    function isSameCompany(companyId) {
      return isAuthenticated() && (
        request.auth.token.companyId == companyId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId)
      );
    }
    
    // Regras para a coleção de usuários
    match /users/{userId} {
      // Autenticação customizada (email/senha no Firestore, sessão via localStorage)
      allow read: if true;
      allow create: if request.resource.data.role == 'company_user' ||
                    request.resource.data.role == 'admin';
      allow update: if true;
      allow delete: if isAdmin();
    }
    
    // Regras para a coleção de empresas
    match /companies/{companyId} {
      allow read: if true;
      allow create: if request.resource.data.name is string &&
                    request.resource.data.code is string &&
                    request.resource.data.contactEmail is string;
      allow update, delete: if isAdmin();
    }
    
    // Regras para a coleção de shipments
    match /shipments/{shipmentId} {
      // Staff (admin/operador) pode ler/escrever qualquer shipment
      allow read, write: if isStaff();
      
      // Usuários de empresa podem apenas ler e atualizar shipments da sua empresa
      allow read, update: if isAuthenticated() && 
                           isSameCompany(resource.data.companyId);
      
      // Staff ou empresa pode criar envios (empresa só na própria companyId)
      allow create: if isStaff() ||
        (isCompanyUser() &&
         request.resource.data.companyId == getUserCompanyId());
    }
    
    // Regras para histórico de status dos embarques
    match /statusHistory/{historyId} {
      allow read: if isStaff() ||
        (isAuthenticated() && isSameCompany(resource.data.companyId));

      allow create: if isStaff() ||
        (isAuthenticated() &&
         isSameCompany(request.resource.data.companyId));

      allow update, delete: if isAdmin();
    }

    // Templates de notificação (apenas admin)
    match /notificationTemplates/{templateId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Notificações in-app (Firebase push + histórico no painel)
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isStaff();
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Regras para a coleção de documentos
    match /documents/{documentId} {
      // Staff pode ler/escrever qualquer documento
      allow read, write: if isStaff();
      
      // Usuários de empresa podem ler documentos de shipments da sua empresa
      allow read: if isAuthenticated() && 
                   exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                   exists(/databases/$(database)/documents/shipments/$(resource.data.shipmentId)) &&
                   get(/databases/$(database)/documents/shipments/$(resource.data.shipmentId)).data.companyId == 
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
      
      allow create, update, delete: if isStaff();
    }
    
    // Regras padrão (negação para outras coleções)
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 